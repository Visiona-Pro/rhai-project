# GEMINI_API_KEY: Não é necessária para este projeto (removido do metadata.json).
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OBRIGATÓRIO — substitua pelo seu ID real antes do deploy
# Formato: G-XXXXXXXXXX (encontre em analytics.google.com)
VITE_GA_TRACKING_ID=""

# OBRIGATÓRIO — substitua pelo seu ID real antes do deploy
# Formato: número de 15 dígitos (encontre em business.facebook.com/events-manager)
VITE_META_PIXEL_ID=""

# VITE_CHECKOUT_URL: Optional custom checkout URL (e.g., https://pay.kiwify.com.br/xxxxx). Must end with kiwify.com.br
VITE_CHECKOUT_URL="https://pay.kiwify.com.br/KgbOBvS"

# VITE_MEMBERS_URL: URL da área de membros do produto específico na Kiwify.
# Formato: https://members.kiwify.com.br/[slug-do-seu-produto]
# Exemplo: https://members.kiwify.com.br/cafe-sem-migalhas
# Encontre o slug no painel Kiwify > Produtos > [seu produto] > Área de Membros
VITE_MEMBERS_URL="https://members.kiwify.com.br/cafe-sem-migalhas"

